{% extends "frontend/_main.html.twig" %}

{% block content %}
    {% for p in formOptions.introductionParagraphs %}
        <p>{{ p }}</p>
    {% endfor %}

    {{ form_start(form) }}

    {% for child in form %}
        {{ form_row(child) }}
    {% endfor %}

    <div class="container-fluid px-0">
        <div class="row">
            <div class="col-md-6">
                <button class="btn btn-primary w-100" type="submit">{{ 'form.submit'|trans }}</button>
            </div>

            <div class="col-md-6">
                <button class="btn btn-secondary w-100" type="reset">{{ 'form.reset'|trans }}</button>
            </div>
        </div>
    </div>

    {{ form_end(form) }}
{% endblock %}